{
  "name": "mathewshen-blog",
  "type": "module",
  "version": "1.6.3",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "NODE_OPTIONS=--max-old-space-size=8192 astro check && NODE_OPTIONS=--max-old-space-size=8192 astro build",
    "preview": "astro preview",
    "astro": "astro",
    "prettier": "prettier --write **/*.{ts,tsx,css,astro} --ignore-path .gitignore --ignore-path .prettierignore"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.8",
    "@astrojs/markdown-remark": "^6.3.11",
    "@astrojs/mdx": "^4.3.14",
    "@astrojs/react": "^4.4.2",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "@expressive-code/plugin-collapsible-sections": "^0.41.7",
    "@expressive-code/plugin-line-numbers": "^0.41.7",
    "@iconify-json/lucide": "^1.2.102",
    "@shikijs/rehype": "^3.23.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/react": "19.2.11",
    "@types/react-dom": "19.2.3",
    "astro": "^6.1.6",
    "astro-icon": "^1.1.5",
    "astro-pagefind": "^1.8.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.563.0",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "rehype-citation": "^2.3.2",
    "rehype-expressive-code": "^0.41.7",
    "rehype-external-links": "^3.0.0",
    "rehype-katex": "^7.0.1",
    "remark-emoji": "^5.0.2",
    "remark-math": "^6.0.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "prettier": "^3.8.2",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-astro-organize-imports": "^0.4.12",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "sharp": "^0.34.5"
  },
  "pnpm": {
    "overrides": {
      "fast-xml-parser": "5.5.7",
      "rollup": "4.59.0",
      "h3": "1.15.9",
      "picomatch": "4.0.4",
      "anymatch>picomatch": "2.3.2",
      "smol-toml": "1.6.1",
      "yaml": "2.8.3",
      "@iconify/tools>svgo": "3.3.3",
      "@iconify/tools>tar": "7.5.11",
      "cheerio>undici": "7.24.0"
    }
  },
  "prettier": {
    "semi": false,
    "singleQuote": true,
    "plugins": [
      "prettier-plugin-astro",
      "prettier-plugin-tailwindcss",
      "prettier-plugin-astro-organize-imports"
    ],
    "overrides": [
      {
        "files": "*.astro",
        "options": {
          "parser": "astro"
        }
      }
    ]
  }
}
